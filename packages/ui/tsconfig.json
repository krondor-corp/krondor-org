{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "strictNullChecks": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react-jsx",
    "lib": ["ES2015", "ES2020", "DOM", "DOM.Iterable"],
    "target": "ES2020"
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.stories.tsx", "**/*.test.tsx", "node_modules", "dist"]
}
